{
  "name": "art-generator-server",
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev --prefix web\"",
    "build:web": "npm run build --prefix web",
    "serve": "npm run build:web && node server.js"
  },
  "dependencies": {
    "express": "^4.19.0",
    "openai": "^4.52.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
